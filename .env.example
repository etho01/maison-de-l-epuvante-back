# Exemple de configuration pour .env.local
# IMPORTANT: Copiez ce fichier vers .env.local et adaptez les valeurs
# Ne committez JAMAIS vos valeurs réelles (.env.local est dans .gitignore)

###> doctrine/doctrine-bundle ###
# Base de données - Plusieurs options selon votre environnement

# MySQL/MariaDB (recommandé pour ce projet)
DATABASE_URL="mysql://root@127.0.0.1:3307/maison_epouvante?serverVersion=mariadb-11.3.0"

# PostgreSQL
# DATABASE_URL="postgresql://user:password@127.0.0.1:5432/maison_de_lepouvante?serverVersion=16&charset=utf8"

# SQLite (développement uniquement)
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
###< doctrine/doctrine-bundle ###

###> symfony/framework-bundle ###
APP_ENV=dev
# Secret Symfony - Générer avec: openssl rand -base64 32
APP_SECRET=changez-moi-en-production-avec-une-valeur-aleatoire
###< symfony/framework-bundle ###

###> nelmio/cors-bundle ###
# CORS Configuration - Autoriser les requêtes cross-origin
# Autoriser localhost et 127.0.0.1 sur tous les ports (développement)
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# En production, limitez aux domaines spécifiques autorisés
# CORS_ALLOW_ORIGIN='^https?://(www\.)?example\.com$'
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
# JWT Passphrase - Générer avec: openssl rand -base64 32
# Cette passphrase est utilisée pour chiffrer les clés RSA
JWT_PASSPHRASE=changez-moi-avec-une-passphrase-forte

# Les clés JWT sont stockées dans Vault en production (encodées en base64)
# En développement local, générez-les avec: php bin/console lexik:jwt:generate-keypair
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
###< lexik/jwt-authentication-bundle ###
symfony/mailer ###
# Mailer DSN - Pour l'envoi d'emails de vérification et réinitialisation de mot de passe

# Désactiver l'envoi (stocke les emails dans var/log) - Recommandé pour le développement
MAILER_DSN=null://null

# Gmail (nécessite un mot de passe d'application - https://myaccount.google.com/apppasswords)
# MAILER_DSN=gmail://username:password@default

# SMTP générique
# MAILER_DSN=smtp://user:pass@smtp.example.com:587

# Mailtrap (pour le développement - https://mailtrap.io)
# MAILER_DSN=smtp://username:password@smtp.mailtrap.io:2525

# Sendgrid (https://sendgrid.com)
# MAILER_DSN=sendgrid://KEY@default

# Mailgun (https://mailgun.com)
# MAILER_DSN=mailgun://KEY:DOMAIN@default?region=us
###< symfony/mER_DSN=null://null
###< Mailer ###

###> stripe/stripe-php ###
# Clé de test Stripe (obtenir la vôtre sur https://dashboard.stripe.com/test/apikeys)
# Format: sk_test_xxx pour le test, sk_live_xxx pour la production
# Documentation: https://stripe.com/docs/keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
###< stripe/stripe-php ###

###> Routing & URLs ###
# URL de base de l'API
DEFAULT_URI=http://localhost:8000

# URL du frontend (pour les liens dans les emails)
FRONTEND_URL=http://localhost:3000
###< Routing & URLs ###

###> PHPUnit Testing ###
# Token utilisé pour l'isolation de la base de données de test
TEST_TOKEN=
###< PHPUnit Testing ###
