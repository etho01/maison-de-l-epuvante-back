# Variables d'environnement définies par Kubernetes
# Les valeurs ci-dessous sont des placeholders pour le build Docker
# Les vraies valeurs sont injectées via les secrets Kubernetes au runtime

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=build_time_placeholder_secret_will_be_overridden
DATABASE_URL="mysql://user:pass@localhost:3306/db?serverVersion=8.0"
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=db
DATABASE_USER=user
DATABASE_PASSWORD=pass
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
